// Este generator está configurado para usar TypeScript estricto
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMERACIONES (Mapeadas a CHECK constraints o ENUMs en Postgres)
// ==========================================

enum EstadoProducto {
  BORRADOR
  ACTIVO
  INACTIVO
}

enum TipoAtributo {
  TEXTO
  NUMERO
  COLOR
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE
  RESERVA
  LIBERACION
}

enum EstadoOrdenCompra {
  PENDIENTE
  APROBADA
  RECIBIDA_PARCIAL
  RECIBIDA
  CANCELADA
}

enum MetodoPago {
  TARJETA
  TRANSFERENCIA
  CONTRA_ENTREGA
  CREDITO
}

enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
  REEMBOLSADO
}

enum TipoAjuste {
  GANANCIA
  PERDIDA
}

enum TipoConfiguracion {
  STRING
  INT
  BOOLEAN
  JSON
}

// ==========================================
// MÓDULO TRANSVERSAL Y SEGURIDAD
// ==========================================

model Moneda {
  id          Int          @id @default(autoincrement()) @map("id")
  codigo      String       @unique @db.VarChar(3)
  nombre      String       @db.VarChar(50)
  simbolo     String       @db.VarChar(5)
  activo      Boolean      @default(true)
  created_at  DateTime     @default(now()) @map("created_at")
  tipoCambiosOrigen  TipoCambio[] @relation("Origen")
  tipoCambiosDestino TipoCambio[] @relation("Destino")

  @@map("monedas")
}

model TipoCambio {
  id               Int      @id @default(autoincrement()) @map("id")
  monedaOrigenId   Int      @map("moneda_origen_id")
  monedaDestinoId  Int      @map("moneda_destino_id")
  tasa             Decimal  @db.Decimal(10, 4)
  fechaRegistro    DateTime @default(now()) @map("fecha_registro") @db.Date()
  monedaOrigen     Moneda   @relation("Origen", fields: [monedaOrigenId], references: [id])
  monedaDestino    Moneda   @relation("Destino", fields: [monedaDestinoId], references: [id])

  @@map("tipo_cambio")
}

model ConfiguracionSistema {
  id         Int      @id @default(autoincrement()) @map("id")
  clave      String   @unique @db.VarChar(100)
  valor      String   @db.Text
  tipo       TipoConfiguracion @default(STRING) @map("tipo")
  updated_at DateTime @default(now()) @map("updated_at")

  @@map("configuracion_sistema")
}

model SegPermiso {
  id         Int      @id @default(autoincrement()) @map("id")
  nombre     String   @unique @db.VarChar(100)
  descripcion String? @db.VarChar(255)
  created_at DateTime @default(now()) @map("created_at")
  roles      SegRolPermiso[]

  @@map("seg_permisos")
}

model SegRol {
  id          Int              @id @default(autoincrement()) @map("id")
  nombre      String           @unique @db.VarChar(50)
  descripcion String?          @db.VarChar(255)
  created_at  DateTime         @default(now()) @map("created_at")
  permisos    SegRolPermiso[]
  usuarios    SegUsuarioRol[]

  @@map("seg_roles")
}

// Tabla intermedia explícita para mantener convención de nombres
model SegRolPermiso {
  rolId      Int @map("rol_id")
  permisoId  Int @map("permiso_id")
  rol        SegRol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso    SegPermiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("seg_rol_permiso")
}

enum FrecuenciaReporte {
  DIARIA
  SEMANAL
  MENSUAL
}

model RepProgramacion {
  id            String            @id @default(uuid()) @map("id") @db.Uuid
  nombre        String            @db.VarChar(100)
  tipoReporte   String            @map("tipo_reporte") @db.VarChar(50)
  frecuencia    FrecuenciaReporte
  formato       String            @db.VarChar(10)
  destinatarios String            @db.Text
  campos        Json?             @db.JsonB
  ultimoEnvio   DateTime?         @map("ultimo_envio")
  proximoEnvio  DateTime?         @map("proximo_envio")
  activo        Boolean           @default(true)
  created_at    DateTime          @default(now()) @map("created_at")
  updated_at    DateTime          @updatedAt @map("updated_at")
  createdBy     String?           @map("created_by") @db.Uuid
  usuario       SegUsuario?       @relation("ProgramadorReportes", fields: [createdBy], references: [id])

  @@map("rep_programaciones")
}

model SegUsuario {
  id             String          @id @default(uuid()) @map("id") @db.Uuid
  correo         String          @unique @db.VarChar(150)
  contrasenaHash String          @map("contrasena_hash") @db.VarChar(255)
  activo         Boolean         @default(true)
  created_at     DateTime        @default(now()) @map("created_at")
  updated_at     DateTime        @updatedAt @map("updated_at")
  cliente        CliCliente?
  roles          SegUsuarioRol[]
  auditorias     AuditoriaRegistro[] @relation("Auditor")
  inventario     InvMovimientoInventario[] @relation("MovimientoInv")
  productosCreados CatProducto[] @relation("ProductoCreador")
  ajustesInventario InvAjuste[] @relation("AjusteInv")
  ordenesCompraInventario InvOrdenCompra[] @relation("OrdenCompraInv")
  recepcionesInventario InvRecepcion[] @relation("RecepcionInv")
  ordenesCreadas OrdOrden[] @relation("OrdenCreador")
  historialEstadoOrdenes OrdHistorialEstado[] @relation("HistorialEstadoOrd")
  programacionesReportes RepProgramacion[] @relation("ProgramadorReportes")

  @@map("seg_usuarios")
}

model SegUsuarioRol {
  usuarioId  String   @map("usuario_id") @db.Uuid
  rolId      Int      @map("rol_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  usuario    SegUsuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol        SegRol     @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@id([usuarioId, rolId])
  @@map("seg_usuario_rol")
}

model AuditoriaRegistro {
  id             BigInt   @id @default(autoincrement()) @map("id")
  tablaAfectada  String   @map("tabla_afectada") @db.VarChar(50)
  registroId     String   @map("registro_id") @db.Uuid
  accion         String   @map("accion") @db.VarChar(20)
  datosAnteriores Json?   @map("datos_anteriores") @db.JsonB
  datosNuevos    Json?    @map("datos_nuevos") @db.JsonB
  usuarioEjecutorId String? @map("usuario_ejecutor") @db.Uuid
  fechaAccion    DateTime @default(now()) @map("fecha_accion")
  usuarioEjecutor SegUsuario? @relation("Auditor", fields: [usuarioEjecutorId], references: [id])

  @@map("auditoria_registro")
}

// ==========================================
// MÓDULO DE CATÁLOGO
// ==========================================

model CatCategoria {
  id            String           @id @default(uuid()) @map("id") @db.Uuid
  nombre        String           @db.VarChar(100)
  slug          String           @unique @db.VarChar(100)
  activo        Boolean          @default(true)
  created_at    DateTime         @default(now()) @map("created_at")
  updated_at    DateTime         @updatedAt @map("updated_at")
  subcategorias CatSubcategoria[]
  productos     CatProducto[]

  @@map("cat_categorias")
}

model CatSubcategoria {
  id          String       @id @default(uuid()) @map("id") @db.Uuid
  categoriaId String       @map("categoria_id") @db.Uuid
  nombre      String       @db.VarChar(100)
  slug        String       @db.VarChar(100)
  activo      Boolean      @default(true)
  created_at  DateTime     @default(now()) @map("created_at")
  categoria   CatCategoria @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  productos   CatProducto[]

  @@unique([categoriaId, slug])
  @@map("cat_subcategorias")
}

model CatMarca {
  id         String       @id @default(uuid()) @map("id") @db.Uuid
  nombre     String       @unique @db.VarChar(100)
  activo     Boolean      @default(true)
  created_at DateTime     @default(now()) @map("created_at")
  productos  CatProducto[]

  @@map("cat_marcas")
}

model CatUnidadMedida {
  id         String       @id @default(uuid()) @map("id") @db.Uuid
  nombre     String       @db.VarChar(50)
  abreviatura String      @db.VarChar(10)
  activo     Boolean      @default(true)
  productos  CatProducto[]

  @@map("cat_unidades_medida")
}

model CatAtributo {
  id         String             @id @default(uuid()) @map("id") @db.Uuid
  nombre     String             @db.VarChar(50)
  tipoValor  TipoAtributo       @map("tipo_valor")
  activo     Boolean            @default(true)
  valores    CatValorAtributo[]

  @@map("cat_atributos")
}

model CatValorAtributo {
  id         String              @id @default(uuid()) @map("id") @db.Uuid
  atributoId String              @map("atributo_id") @db.Uuid
  valor      String              @db.VarChar(100)
  atributo   CatAtributo         @relation(fields: [atributoId], references: [id], onDelete: Cascade)
  productos  CatProductoAtributo[]

  @@unique([atributoId, valor])
  @@map("cat_valores_atributo")
}

model CatProducto {
  id                String                @id @default(uuid()) @map("id") @db.Uuid
  sku               String                @unique @db.VarChar(50)
  nombre            String                @db.VarChar(200)
  slug              String                @unique @db.VarChar(255)
  descripcionCorta  String?               @map("descripcion_corta") @db.Text
  descripcionLarga  String?               @map("descripcion_larga") @db.Text
  categoriaId       String                @map("categoria_id") @db.Uuid
  subcategoriaId    String?               @map("subcategoria_id") @db.Uuid
  marcaId           String?               @map("marca_id") @db.Uuid
  unidadMedidaId    String?               @map("unidad_medida_id") @db.Uuid
  precioCosto       Decimal               @default(0.00) @map("precio_costo") @db.Decimal(12, 2)
  precioVenta       Decimal               @map("precio_venta") @db.Decimal(12, 2)
  precioOferta      Decimal?              @map("precio_oferta") @db.Decimal(12, 2)
  fechaInicioOferta DateTime?             @map("fecha_inicio_oferta") @db.Timestamptz()
  fechaFinOferta    DateTime?             @map("fecha_fin_oferta") @db.Timestamptz()
  peso              Decimal?              @db.Decimal(10, 3)
  estado            EstadoProducto        @default(ACTIVO)
  activo            Boolean               @default(true)
  createdBy         String?               @map("created_by") @db.Uuid
  created_at        DateTime              @default(now()) @map("created_at")
  updated_at        DateTime              @updatedAt @map("updated_at")
  
  categoria         CatCategoria          @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  subcategoria      CatSubcategoria?      @relation(fields: [subcategoriaId], references: [id], onDelete: SetNull)
  marca             CatMarca?             @relation(fields: [marcaId], references: [id], onDelete: SetNull)
  unidadMedida      CatUnidadMedida?      @relation(fields: [unidadMedidaId], references: [id], onDelete: SetNull)
  creador           SegUsuario?           @relation("ProductoCreador", fields: [createdBy], references: [id])
  
  imagenes          CatImagenProducto[]
  etiquetas         CatProductoEtiqueta[]
  atributos         CatProductoAtributo[]
  stock             InvStockProducto?
  itemsCarrito      OrdItemCarrito[]
  itemsOrden        OrdItemOrden[]
  itemsListaDeseo   CliItemListaDeseos[]
  resenas           CliResenaProducto[]
  historialNav      CliHistorialNavegacion[]
  detalleCompra     InvDetalleOrdenCompra[]

  @@index([categoriaId], map: "idx_productos_categoria")
  @@index([estado], map: "idx_productos_estado")
  @@map("cat_productos")
}

model CatImagenProducto {
  id         String      @id @default(uuid()) @map("id") @db.Uuid
  productoId String      @map("producto_id") @db.Uuid
  url        String      @db.Text
  orden      Int         @default(0)
  created_at DateTime    @default(now()) @map("created_at")
  producto   CatProducto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@map("cat_imagenes_producto")
}

model CatEtiqueta {
  id        String               @id @default(uuid()) @map("id") @db.Uuid
  nombre    String               @unique @db.VarChar(50)
  productos CatProductoEtiqueta[]

  @@map("cat_etiquetas")
}

model CatProductoEtiqueta {
  productoId String      @map("producto_id") @db.Uuid
  etiquetaId String      @map("etiqueta_id") @db.Uuid
  producto   CatProducto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  etiqueta   CatEtiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([productoId, etiquetaId])
  @@map("cat_producto_etiqueta")
}

model CatProductoAtributo {
  id              String             @id @default(uuid()) @map("id") @db.Uuid
  productoId      String             @map("producto_id") @db.Uuid
  valorAtributoId String             @map("valor_atributo_id") @db.Uuid
  producto        CatProducto        @relation(fields: [productoId], references: [id], onDelete: Cascade)
  valorAtributo   CatValorAtributo   @relation(fields: [valorAtributoId], references: [id], onDelete: Cascade)

  @@unique([productoId, valorAtributoId])
  @@map("cat_producto_atributo")
}

// ==========================================
// MÓDULO DE CLIENTES
// ==========================================

model CliCliente {
  id                  String                 @id @default(uuid()) @map("id") @db.Uuid
  usuarioId           String                 @unique @map("usuario_id") @db.Uuid
  nombre              String                 @db.VarChar(100)
  apellido            String                 @db.VarChar(100)
  documentoIdentidad  String?                @unique @map("documento_identidad") @db.VarChar(20)
  telefono            String?                @db.VarChar(20)
  fechaNacimiento     DateTime?              @map("fecha_nacimiento") @db.Date()
  limiteCredito       Decimal                @default(0) @map("limite_credito") @db.Decimal(12, 2)
  saldoDeudor         Decimal                @default(0) @map("saldo_deudor") @db.Decimal(12, 2)
  activo              Boolean                @default(true)
  created_at          DateTime               @default(now()) @map("created_at")
  updated_at          DateTime               @updatedAt @map("updated_at")
  
  usuario             SegUsuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  direcciones         CliDireccion[]
  listaDeseos         CliListaDeseos?
  resenas             CliResenaProducto[]
  historialNav        CliHistorialNavegacion[]
  carritos            OrdCarrito[]
  ordenes             OrdOrden[]

  @@map("cli_clientes")
}

model CliDireccion {
  id               String      @id @default(uuid()) @map("id") @db.Uuid
  clienteId        String      @map("cliente_id") @db.Uuid
  alias            String      @db.VarChar(50)
  nombreReceptor   String      @map("nombre_receptor") @db.VarChar(200)
  direccion        String      @db.Text
  ciudad           String      @db.VarChar(100)
  departamento     String      @db.VarChar(100)
  codigoPostal     String?     @map("codigo_postal") @db.VarChar(10)
  telefonoReceptor String?     @map("telefono_receptor") @db.VarChar(20)
  esPrincipal      Boolean     @default(false) @map("es_principal")
  created_at       DateTime    @default(now()) @map("created_at")
  cliente          CliCliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("cli_direcciones")
}

model CliListaDeseos {
  id         String              @id @default(uuid()) @map("id") @db.Uuid
  clienteId  String              @unique @map("cliente_id") @db.Uuid
  created_at DateTime            @default(now()) @map("created_at")
  cliente    CliCliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  items      CliItemListaDeseos[]

  @@map("cli_lista_deseos")
}

model CliItemListaDeseos {
  listaDeseosId String           @map("lista_deseos_id") @db.Uuid
  productoId    String           @map("producto_id") @db.Uuid
  addedAt       DateTime         @default(now()) @map("added_at")
  listaDeseos   CliListaDeseos   @relation(fields: [listaDeseosId], references: [id], onDelete: Cascade)
  producto      CatProducto      @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@id([listaDeseosId, productoId])
  @@map("cli_items_lista_deseos")
}

model CliResenaProducto {
  id          String      @id @default(uuid()) @map("id") @db.Uuid
  productoId  String      @map("producto_id") @db.Uuid
  clienteId   String      @map("cliente_id") @db.Uuid
  calificacion Int        @db.SmallInt
  comentario  String?    @db.Text
  activo      Boolean     @default(true)
  created_at  DateTime    @default(now()) @map("created_at")
  producto    CatProducto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  cliente     CliCliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([productoId, clienteId])
  @@map("cli_resenas_producto")
}

model CliHistorialNavegacion {
  id         String      @id @default(uuid()) @map("id") @db.Uuid
  clienteId  String      @map("cliente_id") @db.Uuid
  productoId String      @map("producto_id") @db.Uuid
  vistoEn    DateTime    @default(now()) @map("visto_en")
  cliente    CliCliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  producto   CatProducto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([clienteId, vistoEn(sort: Desc)], map: "idx_historial_cliente")
  @@map("cli_historial_navegacion")
}

// ==========================================
// MÓDULO DE INVENTARIO
// ==========================================

model InvProveedor {
  id               String              @id @default(uuid()) @map("id") @db.Uuid
  ruc              String              @unique @db.VarChar(11)
  razonSocial      String              @map("razon_social") @db.VarChar(200)
  contactoNombre   String?             @map("contacto_nombre") @db.VarChar(100)
  contactoTelefono String?             @map("contacto_telefono") @db.VarChar(20)
  email            String?             @db.VarChar(150)
  direccion        String?             @db.Text
  activo           Boolean             @default(true)
  created_at       DateTime            @default(now()) @map("created_at")
  ordenesCompra    InvOrdenCompra[]

  @@map("inv_proveedores")
}

model InvStockProducto {
  id             String                    @id @default(uuid()) @map("id") @db.Uuid
  productoId     String                    @unique @map("producto_id") @db.Uuid
  stockFisico    Int                       @default(0) @map("stock_fisico")
  stockReservado Int                       @default(0) @map("stock_reservado")
  stockMinimo    Int                       @default(5) @map("stock_minimo")
  updated_at     DateTime                  @updatedAt @map("updated_at")
  producto       CatProducto               @relation(fields: [productoId], references: [id], onDelete: Restrict)
  movimientos    InvMovimientoInventario[]
  detallesAjuste InvDetalleAjuste[]

  @@map("inv_stock_producto")
}

model InvMovimientoInventario {
  id              String           @id @default(uuid()) @map("id") @db.Uuid
  stockId         String           @map("stock_id") @db.Uuid
  tipoMovimiento  TipoMovimiento   @map("tipo_movimiento")
  cantidad        Int
  referenciaId    String?          @map("referencia_id") @db.Uuid
  referenciaTipo  String?          @map("referencia_tipo") @db.VarChar(50)
  comentario      String?          @db.Text
  createdBy       String?          @map("created_by") @db.Uuid
  created_at      DateTime         @default(now()) @map("created_at")
  stock           InvStockProducto @relation(fields: [stockId], references: [id])
  usuario         SegUsuario?      @relation("MovimientoInv", fields: [createdBy], references: [id])

  @@index([stockId, created_at(sort: Desc)], map: "idx_movimientos_stock")
  @@map("inv_movimientos_inventario")
}

model InvAjuste {
  id         String              @id @default(uuid()) @map("id") @db.Uuid
  motivo     String              @db.VarChar(200)
  tipo       TipoAjuste
  createdBy  String              @map("created_by") @db.Uuid
  created_at DateTime            @default(now()) @map("created_at")
  usuario    SegUsuario          @relation("AjusteInv", fields: [createdBy], references: [id])
  detalles   InvDetalleAjuste[]

  @@map("inv_ajustes")
}

model InvDetalleAjuste {
  ajusteId  String           @map("ajuste_id") @db.Uuid
  stockId   String           @map("stock_id") @db.Uuid
  cantidad  Int
  ajuste    InvAjuste        @relation(fields: [ajusteId], references: [id], onDelete: Cascade)
  stock     InvStockProducto @relation(fields: [stockId], references: [id])

  @@id([ajusteId, stockId])
  @@map("inv_detalle_ajuste")
}

model InvOrdenCompra {
  id              String                   @id @default(uuid()) @map("id") @db.Uuid
  proveedorId     String?                  @map("proveedor_id") @db.Uuid
  estado          EstadoOrdenCompra        @default(PENDIENTE)
  fechaOrden      DateTime                 @default(now()) @map("fecha_orden")
  createdBy       String?                  @map("created_by") @db.Uuid
  created_at      DateTime                 @default(now()) @map("created_at")
  proveedor       InvProveedor?            @relation(fields: [proveedorId], references: [id])
  usuario         SegUsuario?              @relation("OrdenCompraInv", fields: [createdBy], references: [id])
  detalles        InvDetalleOrdenCompra[]
  recepciones     InvRecepcion[]

  @@map("inv_ordenes_compra")
}

model InvDetalleOrdenCompra {
  id                 String           @id @default(uuid()) @map("id") @db.Uuid
  ordenCompraId      String           @map("orden_compra_id") @db.Uuid
  productoId         String           @map("producto_id") @db.Uuid
  cantidadSolicitada Int              @map("cantidad_solicitada")
  cantidadRecibida   Int              @default(0) @map("cantidad_recibida")
  costoUnitario      Decimal          @map("costo_unitario") @db.Decimal(12, 2)
  ordenCompra        InvOrdenCompra   @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  producto           CatProducto      @relation(fields: [productoId], references: [id])

  @@map("inv_detalle_orden_compra")
}

model InvRecepcion {
  id              String          @id @default(uuid()) @map("id") @db.Uuid
  ordenCompraId   String?         @map("orden_compra_id") @db.Uuid
  fechaRecepcion  DateTime        @default(now()) @map("fecha_recepcion")
  recibidoPor     String?         @map("recibido_por") @db.Uuid
  comentario      String?         @db.Text
  ordenCompra     InvOrdenCompra? @relation(fields: [ordenCompraId], references: [id])
  usuario         SegUsuario?     @relation("RecepcionInv", fields: [recibidoPor], references: [id])

  @@map("inv_recepciones")
}

// ==========================================
// MÓDULO DE ÓRDENES Y CARRITO
// ==========================================

model OrdMetodoEnvio {
  id           String       @id @default(uuid()) @map("id") @db.Uuid
  nombre       String       @db.VarChar(50)
  descripcion  String?      @db.Text
  tiempoEstimado String?    @map("tiempo_estimado") @db.VarChar(50)
  precioBase   Decimal      @map("precio_base") @db.Decimal(10, 2)
  activo       Boolean      @default(true)
  ordenes      OrdOrden[]

  @@map("ord_metodos_envio")
}

model OrdEstadoOrden {
  id     Int     @id @default(autoincrement()) @map("id")
  nombre String  @unique @db.VarChar(50)
  ordenes OrdOrden[]
  historial OrdHistorialEstado[]

  @@map("ord_estados_orden")
}

model OrdDireccionEnvio {
  id               String      @id @default(uuid()) @map("id") @db.Uuid
  alias            String?     @db.VarChar(50)
  nombreReceptor   String      @map("nombre_receptor") @db.VarChar(200)
  direccion        String      @db.Text
  ciudad           String      @db.VarChar(100)
  departamento     String      @db.VarChar(100)
  codigoPostal     String?     @map("codigo_postal") @db.VarChar(10)
  telefonoReceptor String?     @map("telefono_receptor") @db.VarChar(20)
  created_at       DateTime    @default(now()) @map("created_at")
  orden            OrdOrden?

  @@map("ord_direcciones_envio")
}

model OrdCarrito {
  id         String          @id @default(uuid()) @map("id") @db.Uuid
  clienteId  String?         @unique @map("cliente_id") @db.Uuid
  updated_at DateTime        @updatedAt @map("updated_at")
  cliente    CliCliente?     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  items      OrdItemCarrito[]

  @@map("ord_carritos")
}

model OrdItemCarrito {
  id             String      @id @default(uuid()) @map("id") @db.Uuid
  carritoId      String      @map("carrito_id") @db.Uuid
  productoId     String      @map("producto_id") @db.Uuid
  cantidad       Int
  precioUnitario Decimal     @map("precio_unitario") @db.Decimal(12, 2)
  created_at     DateTime    @default(now()) @map("created_at")
  carrito        OrdCarrito  @relation(fields: [carritoId], references: [id], onDelete: Cascade)
  producto       CatProducto @relation(fields: [productoId], references: [id])

  @@unique([carritoId, productoId])
  @@map("ord_items_carrito")
}

model OrdOrden {
  id                String               @id @default(uuid()) @map("id") @db.Uuid
  clienteId         String               @map("cliente_id") @db.Uuid
  numeroOrden       String               @unique @map("numero_orden") @db.VarChar(20)
  direccionEnvioId  String               @unique @map("direccion_envio_id") @db.Uuid
  metodoEnvioId     String               @map("metodo_envio_id") @db.Uuid
  estadoOrdenId     Int                  @default(1) @map("estado_orden_id")
  subtotal          Decimal              @db.Decimal(12, 2)
  porcentajeIgv     Decimal              @default(18) @map("porcentaje_igv") @db.Decimal(5, 2)
  montoIgv          Decimal              @default(0) @map("monto_igv") @db.Decimal(12, 2)
  totalEnvio        Decimal              @default(0) @map("total_envio") @db.Decimal(10, 2)
  descuentoTotal    Decimal              @default(0) @map("descuento_total") @db.Decimal(12, 2)
  totalFinal        Decimal              @db.Decimal(12, 2)
  codigoCupon       String?              @map("codigo_cupon") @db.VarChar(50)
  notasCliente      String?              @map("notas_cliente") @db.Text
  createdBy         String?              @map("created_by") @db.Uuid
  created_at        DateTime             @default(now()) @map("created_at")
  updated_at        DateTime             @updatedAt @map("updated_at")
  
  cliente           CliCliente           @relation(fields: [clienteId], references: [id])
  direccionEnvio    OrdDireccionEnvio    @relation(fields: [direccionEnvioId], references: [id])
  metodoEnvio       OrdMetodoEnvio       @relation(fields: [metodoEnvioId], references: [id])
  estado            OrdEstadoOrden       @relation(fields: [estadoOrdenId], references: [id])
  creador           SegUsuario?          @relation("OrdenCreador", fields: [createdBy], references: [id])
  items             OrdItemOrden[]
  historial         OrdHistorialEstado[]
  pago              OrdPago?

  @@index([clienteId, created_at(sort: Desc)], map: "idx_ordenes_cliente")
  @@index([estadoOrdenId], map: "idx_ordenes_estado")
  @@index([numeroOrden], map: "idx_ordenes_numero")
  @@map("ord_ordenes")
}

model OrdItemOrden {
  id             String      @id @default(uuid()) @map("id") @db.Uuid
  ordenId        String      @map("orden_id") @db.Uuid
  productoId     String      @map("producto_id") @db.Uuid
  nombreProducto String      @map("nombre_producto") @db.VarChar(200)
  sku            String      @db.VarChar(50)
  cantidad       Int
  precioUnitario Decimal     @map("precio_unitario") @db.Decimal(12, 2)
  subtotal       Decimal     @db.Decimal(12, 2)
  orden          OrdOrden    @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  producto       CatProducto @relation(fields: [productoId], references: [id])

  @@map("ord_items_orden")
}

model OrdHistorialEstado {
  id            String          @id @default(uuid()) @map("id") @db.Uuid
  ordenId       String          @map("orden_id") @db.Uuid
  estadoOrdenId Int             @map("estado_orden_id")
  comentario    String?         @db.Text
  usuarioAccion String?         @map("usuario_accion") @db.Uuid
  created_at    DateTime        @default(now()) @map("created_at")
  orden         OrdOrden        @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  estado        OrdEstadoOrden  @relation(fields: [estadoOrdenId], references: [id])
  usuario       SegUsuario?     @relation("HistorialEstadoOrd", fields: [usuarioAccion], references: [id])

  @@map("ord_historial_estados")
}

model OrdPago {
  id             String                  @id @default(uuid()) @map("id") @db.Uuid
  ordenId        String                  @unique @map("orden_id") @db.Uuid
  metodoPago     MetodoPago              @map("metodo_pago")
  estado         EstadoPago              @default(PENDIENTE)
  montoPagado    Decimal                 @map("monto_pagado") @db.Decimal(12, 2)
  created_at     DateTime                @default(now()) @map("created_at")
  updated_at     DateTime                @updatedAt @map("updated_at")
  orden          OrdOrden                @relation(fields: [ordenId], references: [id])
  transacciones  OrdTransaccionPago[]

  @@map("ord_pagos")
}

model OrdTransaccionPago {
  id           String      @id @default(uuid()) @map("id") @db.Uuid
  pagoId       String      @map("pago_id") @db.Uuid
  pasarelaId   String?     @map("pasarela_id") @db.VarChar(100)
  respuestaJson Json?      @map("respuesta_json") @db.JsonB
  created_at   DateTime    @default(now()) @map("created_at")
  pago         OrdPago     @relation(fields: [pagoId], references: [id], onDelete: Cascade)

  @@map("ord_transacciones_pago")
}