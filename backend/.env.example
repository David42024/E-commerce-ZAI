# ==========================================
# ENTORNO Y SERVIDOR
# ==========================================
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# ==========================================
# BASE DE DATOS POSTGRESQL
# ==========================================
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgresql://postgres:12345@localhost:5432/ecommerce_db

# ==========================================
# AUTENTICACIÓN JWT
# ==========================================
# En producción usar generadores de strings aleatorios de 64+ caracteres
JWT_SECRET=super_secret_jwt_key_change_in_production_123456
JWT_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=super_secret_refresh_key_change_in_production_789101
REFRESH_TOKEN_EXPIRES_IN=7d